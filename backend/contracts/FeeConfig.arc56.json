                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Owner-only method to update the treasury address.\nValidation: 1. Caller must be owner (checked first)\nEmits event with old and new treasury addresses.",
            "events": [
